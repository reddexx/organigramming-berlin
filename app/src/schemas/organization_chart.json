{
  "title": "Organization chart",
  "description": "Organization chart for Berlin's administration",
  "version": "0.0.1",
  "definitions": {
    "additionalProperties": false,
    "document": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "title": "Titel"
