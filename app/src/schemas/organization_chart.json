      "avatar": {
        "type": "string",
        "title": "Avatar"
      }
      },

      "required": ["id", "name"],
      "title": "Organisation"
    },
    "department": {
      "type": "object",
      "additionalProperties": false,
      "title": "Zugehörige Organisationseinheit",
      "properties": {
        "name": {
          "type": "string",
          "title": "Abteilung/Stellenbezeichnung",
          "default": "Neue Organisationsuntereinheit"
        },
        "purpose": {
          "type": "string",
          "title": "Beschreibung"
        },
        "type": {
          "type": "string",
          "examples": [
            "Abteilung",
            "Amt",
            "Bezirksamt",
            "Büro",
            "Fachbereich",
            "Fachdienst",
            "Landesamt",
            "Landesstelle",
            "Museum",
            "Other",
            "Referat",
            "Senatskanzlei",
            "Senatsverwaltung",
            "Serviceeinheit",
            "Öffentliches Unternehmen",
            "Unternehmen"
          ],
          "title": "Art der Organisationseinheiten"
        },
        "uri": {
          "$ref": "#/definitions/uri"
        },
        "positions": {
          "title": "Positionen",
          "type": "array",
          "items": {
            "$ref": "#/definitions/position"
          }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "positionType": {
          "type": "string",
          "title": "Art der Rolle",
          "examples": [
            "Büroleiter:in",
            "Pressesprecher:in",
            "Referent:in",
            "Senator:in",
            "Staatssekretär:in"
          ]
        },
        "positionStatus": {
          "type": "string",
          "title": "Zusatzbezeichnung",
          "examples": ["stellvertretend", "kommissarisch", "N.N."]
        },
        "uri": {
          "$ref": "#/definitions/uri"
        },
        "person": {
          "$ref": "#/definitions/person"
        }
      }
    },
    "person": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
       "highlight": {
          "type": "boolean",
          "title": "Person hervorheben",
          "default": false
        },
        "salutation": {
          "type": "string",
          "title": "Anrede"
        },
        "title": {
          "type": "string",
          "title": "Titel"
        },
        "firstName": {
          "type": "string",
          "title": "Vorname"
        },
        "lastName": {
          "type": "string",
          "title": "Nachname"
        },
        "gender": {
          "type": "string",
          "title": "Geschlecht",
          "default": "1",
          "enum": ["m", "w", "d", "1"],
          "enumNames": ["Männlich", "Weiblich", "Divers", "ohne Angabe"]
        },
        "contact": {
          "$ref": "#/definitions/contact"
        },
        "uri": {
          "$ref": "#/definitions/uri"
        }
      },
      "title": "Person"
    },
    "sameAsInfo": {
      "type": "object",
      "title": "Information about same as URI",
      "additionalProperties": false,
      "properties": {
        "uriSameAs": {
          "title": "Externe Verknüpfung",
          "type": "string"
        },
        "uriSameAsLabel": {
          "title": "URI Label",
          "type": "string"
        },
        "uriSameAsDescription": {
          "title": "URI Description",
          "type": "string"
        }
      }
    },
    "uri": {
      "title": "Verknüpfungen (URIs)",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uri": {
          "title": "URI",
          "type": "string"
        },
        "sameAsUris": {
          "type": "array",
          "title": "Externe Verknüpfung",
          "items": {
            "$ref": "#/definitions/sameAsInfo"
          }
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "telephone": {
          "type": "string",
          "title": "Telefonnummer"
        },
        "fax": {
          "type": "string",
          "title": "Faxnummer"
        },
        "email": {
          "type": "string",
          "title": "E-Mail"
        },
        "website": {
          "type": "string",
          "title": "Website"
        }
      },
      "title": "Kontaktdaten"
    },
    "address": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "building": {
          "type": "string",
          "title": "Firma"
        },
        "street": {
          "type": "string",
          "title": "Straße"
        },
        "housenumber": {
          "type": "string",
          "title": "Hausnummer"
        },
        "room": {
          "type": "string",
          "title": "Raum"
        },
        "zipCode": {
          "type": "string",
          "format": "int32",
          "title": "PLZ"
        },
        "city": {
          "type": "string",
          "title": "Stadt"
        }
      },
      "title": "Anschrift"
    },
    "export": {
      "title": "Export Options",
      "type": "object",
      "properties": {
        "filename": {
          "type": "string",
          "title": "Dateiname"
        },
        "saveExport": {
          "type": "string",
          "title": "Möchten Sie das Dokument zur erneuten Bearbeitung in einem maschinenlesbaren Format speichern oder das fertige Organigramm exportieren?",
          "default": "save",
          "enum": ["save", "export"],
          "enumNames": ["Speichern", "Exportieren"]
        }
      },
      "dependencies": {
        "saveExport": {
          "oneOf": [
            {
              "properties": {
                "saveExport": {
                  "enum": ["save"]
                }
              }
            },
            {
              "properties": {
                "saveExport": {
                  "enum": ["export"]
                },
                "includeLogo": {
                  "type": "boolean",
                  "title": "Logo beim Exportieren einbetten",
                  "default": true
                },
                "exportType": {
                  "type": "string",
                  "title": "Dateiformat",
                  "default": "pdf",
                  "enum": ["json", "png", "pdf", "rdf"],
                  "enumNames": ["JSON", "PNG", "PDF", "RDF"]
                }
              }
            }
          ]
        },
        "exportType": {
          "oneOf": [
            {
              "properties": {
                "exportType": {
                  "enum": ["json"]
                },
                "excludePersonalData": {
                  "type": "boolean",
                  "title": "Personenbezogene Daten NICHT exportieren",
                  "default": false
                }
              }
            },
            {
              "properties": {
                "exportType": {
                  "enum": ["svg"]
                }
              }
            },
            {
              "properties": {
                "exportType": {
                  "enum": ["png"]
                }
              }
            },
            {
              "properties": {
                "exportType": {
                  "enum": ["pdf"]
                }
              }
            },
            {
              "properties": {
                "exportType": {
                  "enum": ["rdf"]
                },
                "rdfType": {
                  "type": "string",
                  "title": "RDF Format",
                  "default": "json-ld",
                  "enum": ["json-ld", "nquads", "turtle"],
                  "enumNames": ["JSON-LD", "N-Quads", "Turtle"]
                },
                "excludePersonalData": {
                  "type": "boolean",
                  "title": "Personenbezogene Daten NICHT exportieren",
                  "default": false
                },
                "baseUri": {
                  "type": "string",
                  "title": "Basis URI ändern",
                  "default": ""
                }
              }
            }
          ]
        }
      }
    },
    "settings": {
      "title": "Settings Options",
      "type": "object",
      "properties": {
        "validator": {
          "type": "string",
          "title": "Validierung (experimetelles Feature)",
          "default": "",
          "enum": ["", "berlinerVerwaltung"],
          "enumNames": [
            "keine Validierung",
            "für die Berliner Verwaltung (in Bearbeitung)"
          ]
        },
        "roleOptions": {
          "type": "array",
          "title": "Rollen",
          "items": {
            "type": "string",
            "title": "Rolle"
          },
          "default": []
        },
        "departmentOptions": {
          "type": "array",
          "title": "Abteilungen",
          "items": {
            "type": "string",
            "title": "Abteilung"
          },
          "default": []
        },
        "additionalDesignationOptions": {
          "type": "array",
          "title": "Zusatzbezeichnungen",
          "items": {
            "type": "string",
            "title": "Zusatzbezeichnung"
          },
          "default": []
        }
      }
    }
  },
  "properties": {
    "document": {
      "$ref": "#/definitions/document"
    },
    "settings": {
