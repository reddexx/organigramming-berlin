        "paperSize": {
          "type": "string",
          "title": "Ausgabegröße",
          "default": "A4",
          "enum": ["A5", "A4", "A3", "A2", "A1", "A0"]
        },
        "schemaVersion": {
          "type": "string",
          "title": "Schema",
          "default": "0.0.1"
        },
        "paperOrientation": {
          "type": "string",
          "title": "Orientierung",
          "default": "landscape",
          "enum": ["landscape", "portrait"],
          "enumNames": ["Querformat", "Hochformat"]
        },
        "logo": {
          "title": "Logo",
          "type": "string",
          "format": "data-url"
        },
        "version": {
          "type": "string",
          "format": "date",
          "title": "Version"
        },
        "creator": {
          "type": "string",
          "title": "Verfasser:in"
        },
        "note": {
          "type": "string",
          "title": "Fußzeile"
        },
        "isMainChart": {
          "type": "boolean",
          "default": false,
          "title": "Standard Organigramm"
        },
        "layoutMode": {
          "type": "string",
          "title": "Layout Modus",
          "default": "tree",
          "enum": ["tree", "free"],
          "enumNames": ["Baum", "Flexibel"]
        },
        "freeConnections": {
          "type": "array",
          "title": "Freie Verbindungen",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string"
              },
              "sourceNodeId": {
                "type": "string"
              },
              "targetNodeId": {
                "type": "string"
              },
              "sourceAnchor": {
                "type": "string",
                "enum": ["top", "right", "bottom", "left"]
              },
              "targetAnchor": {
                "type": "string",
                "enum": ["top", "right", "bottom", "left"]
              }
            },
            "required": ["id", "sourceNodeId", "targetNodeId", "sourceAnchor", "targetAnchor"]
          }
        },
        "uri": {
          "$ref": "#/definitions/uri"
        }
      },
      "required": ["title"],
      "title": "Document"
    },
